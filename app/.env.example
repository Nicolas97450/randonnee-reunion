# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Mapbox
EXPO_PUBLIC_MAPBOX_TOKEN=your-mapbox-public-token

# Meteo (Open-Meteo est gratuit, cette cle n'est plus utilisee)
# EXPO_PUBLIC_METEO_API_KEY=not-needed

# Sentry (crash reporting)
EXPO_PUBLIC_SENTRY_DSN=https://your-dsn@xxx.ingest.de.sentry.io/xxx
